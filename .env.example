# Copia este archivo a ".env" (en la raiz del repo, junto a docker-compose.yml)
# y completa tus propias credenciales. ".env" esta en .gitignore -- NUNCA
# lo comitees con valores reales.
#
# ---------------------------------------------------------------------------
# SMTP real para el Servicio de Notificaciones (App 4) - envio de correos
# ---------------------------------------------------------------------------
# Por defecto se usa Gmail SMTP. Requiere:
#   1. Verificacion en 2 pasos activada en tu cuenta de Google
#      (https://myaccount.google.com/security)
#   2. Generar una "Contrasena de aplicacion" en
#      https://myaccount.google.com/apppasswords (16 caracteres, sin espacios)
#      -- NO uses tu contrasena normal de Gmail, Google la rechaza para SMTP.
#
# Si prefieres otro proveedor (Outlook, SendGrid, Mailgun, Brevo, etc.) solo
# cambia MAIL_HOST/MAIL_PORT y usa las credenciales de ese proveedor.

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-correo@gmail.com
MAIL_PASSWORD=tu-contrasena-de-aplicacion-16-caracteres
MAIL_FROM=tu-correo@gmail.com
