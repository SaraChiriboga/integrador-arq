<mxfile host="app.diagrams.net">
  <diagram name="C4 - Componente App2 Portal Ciudadano" id="c4-app2">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Actor: Ciudadano -->
        <mxCell id="actor" value="Ciudadano&#10;Solicita reporte" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="40" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Frontend SPA -->
        <mxCell id="frontend" value="Frontend SPA (React)&#10;Formulario + polling de estado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="160" width="280" height="70" as="geometry" />
        </mxCell>

        <!-- Backend API container -->
        <mxCell id="backend" value="Backend API&#10;Java 17 + Spring Boot 3.2" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=13;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="150" y="290" width="560" height="180" as="geometry" />
        </mxCell>

        <!-- Controller -->
        <mxCell id="controller" value="Controller&#10;Expone endpoints REST" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="350" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Service -->
        <mxCell id="service" value="Service&#10;Idempotencia, persistencia,&#10;publica solicitud.osint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="355" y="350" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Listener -->
        <mxCell id="listener" value="Listener&#10;Consume osint.completado,&#10;publica reporte.listo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="530" y="350" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- PostgreSQL -->
        <mxCell id="postgres" value="PostgreSQL&#10;requests, users" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="530" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Redis -->
        <mxCell id="redis" value="Redis&#10;Lock idempotencia (TTL 10 min)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="355" y="530" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- RabbitMQ -->
        <mxCell id="rabbitmq" value="RabbitMQ&#10;solicitud.osint / osint.completado / reporte.listo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="530" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;elbow=vertical;" edge="1" parent="1" source="actor" target="frontend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e2" value="HTTP / JSON" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;elbow=vertical;fontSize=11;" edge="1" parent="1" source="frontend" target="backend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="controller" target="postgres" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="service" target="postgres" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.3;exitY=1;entryX=0.9;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="service" target="redis" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e6" edge="1" parent="1" source="service" target="rabbitmq" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.7;exitY=1;entryX=0.1;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e7" edge="1" parent="1" source="listener" target="rabbitmq" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e8" edge="1" parent="1" source="listener" target="postgres" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.3;exitY=1;entryX=0.9;entryY=0.3;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
